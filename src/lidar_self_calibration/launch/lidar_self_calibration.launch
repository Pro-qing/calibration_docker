<launch>
    <!-- 标定结果保存路径准备 (可选：确保存放目录存在) -->
    <param name="config_dir" value="$(find lidar_self_calibration)/config" />

    <node pkg="lidar_self_calibration" type="lidar_self_calibration_node" name="lidar_calibration" output="screen">
        <!-- 坐标系与路径配置 -->
        <param name="lidar_frame" value="velodyne" />
        <param name="base_frame"  value="base_link" />
        <param name="save_path"   value="/home/ros_ws/src/lidar_self_calibration/param/lidar_calibration.yaml" />

        <!-- ================== 卷尺实际测量区 ================== -->
        <!-- 1. 前向距离测量 -->
        <param name="dist_left_wheel_to_front"  value="2.50" />
        <param name="dist_right_wheel_to_front" value="2.55" />
        
        <!-- 2. 侧向距离测量 -->
        <param name="dist_left_wheel_to_left_wall"   value="1.8" />
        <param name="dist_right_wheel_to_right_wall" value="2.02" />
        
        <!-- 3. 车辆固有参数 -->
        <param name="wheel_track" value="0.68" /> <!-- 左右车轮中心的距离 -->

        <!-- ================== 雷达粗略位置区 ================== -->
        <!-- 帮助算法锁定目标墙，不需要精准，误差几十厘米也没关系 -->
        <param name="guess_lidar_x"       value="1.00" />  <!-- 雷达在后轮中心点前多少米 -->
        <param name="guess_lidar_y"       value="0.00" />  <!-- 雷达在base_link左侧多少米 -->
        <param name="guess_lidar_yaw_deg" value="0.0" />   <!-- 安装航向角粗略估计 -->
        <param name="manual_lidar_height" value="1.80" />  <!-- 雷达离地高度 -->
        
        <!-- 重新映射你的雷达话题名称 -->
        <remap from="/points_16" to="/points_16" />
    </node>
</launch>